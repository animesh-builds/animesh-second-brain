# ── Animesh's Second Brain — environment ───────────────────────────
# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# ── Google (read-only ingestion) ──────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials.
# OAuth client type: Desktop app.
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
# Minted once via `pnpm auth` (ingest/google-auth.ts). Long-lived, read-only.
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN_HERE

# ── Ingestion behavior ────────────────────────────────────────────
# How far back to pull on first run / backfill.
INGEST_WINDOW_DAYS=90
# Where ingested markdown is written (this is the gbrain "source" repo).
BRAIN_SOURCE_DIR=./sources/google
# Cap on a single email/doc body, in characters (guardrail).
MAX_BODY_CHARS=40000
# Max items per source per run (0 = no cap). Keeps backfill within quota.
MAX_ITEMS_PER_SOURCE=0

# ── Brain (gbrain) ────────────────────────────────────────────────
# gbrain is installed globally via Bun; see brain/setup.sh.
# Embeddings provider: ollama (free, local — default) | openai | none.
EMBEDDINGS=ollama
# Only needed if EMBEDDINGS=openai:
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
# Ollama (free path) — official app, served at localhost:11434 (OpenAI-compat /v1):
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
# Run `gbrain import`/`embed` after ingestion writes markdown.
RUN_GBRAIN_SYNC=true

# ── Agent LLM (WhatsApp answers, via OpenClaw) ────────────────────
# Default: FREE local chat model via Ollama (private — chunks never leave your
# Mac). The setup pulls it for you. Override with a different ollama model if you
# like (e.g. qwen2.5:3b).
AGENT_MODEL=ollama/llama3.2
# Optional alternative: Gemini free tier (better quality, but may train on
# prompts — test data only). Leave blank to use the local model above.
GEMINI_API_KEY=

# ── WhatsApp access allowlist (OpenClaw native gate) ──────────────
# Comma-separated E.164 numbers allowed to message the bot and get answers.
# Everyone else is ignored. Leave blank to use pairing-code approval instead.
WHATSAPP_ALLOW_FROM=+919876543210,+919812345678
